datasource db {
  provider = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders Order[]
}

model Product {
  id String @id @default(uuid())

  // Core Identity
  name        String
  slug        String  @unique // Essential for SEO URLs (e.g., decode-parfum.com/santal-33)
  description String? @db.Text // Full, detailed breakdown of the scent profile

  // Pricing & Promos
  price         Float
  discountPrice Float? // Optional: For future holiday sales or markdowns

  // UI & Metadata
  note     String // Short UI tag (e.g., "Woody / Earthy")
  imageUrl String
  tags     String[] // Array for filtering (e.g., ["bestseller", "summer-collection"])

  // Inventory Control
  stock       Int     @default(0) // How many bottles are left in the warehouse
  isAvailable Boolean @default(true) // Toggle visibility to hide products without deleting them

  // System Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 👈 FIXED: The required back-relation for OrderItem
  orderItems OrderItem[]
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  totalAmount Float
  status      OrderStatus @default(PENDING)

  // Razorpay System Fields
  razorpayOrderId   String  @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  shippingAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
